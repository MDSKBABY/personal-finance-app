# MySQL configuration for local development.
MYSQL_DATABASE=personal_finance
MYSQL_USER=finance_user
MYSQL_PASSWORD=finance_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

# Backend reads this JDBC URL when it starts.
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/personal_finance?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8
SPRING_DATASOURCE_USERNAME=finance_user
SPRING_DATASOURCE_PASSWORD=finance_password

# Single-user login configuration.
# Change APP_AUTH_PASSWORD before exposing the app to the public internet.
APP_AUTH_USERNAME=admin
# Prefer APP_AUTH_PASSWORD_HASH for public deployments.
# APP_AUTH_PASSWORD is still supported for local development.
APP_AUTH_PASSWORD=
APP_AUTH_PASSWORD_HASH=$2a$10$replace_with_your_bcrypt_hash
APP_AUTH_SESSION_HOURS=12
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_MAX_FAILED_ATTEMPTS=5
APP_AUTH_LOCK_MINUTES=10
